# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'KeepUpMobile' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    # Patch fmt to disable consteval — Xcode 26.5's Clang is stricter and rejects
    # fmt's consteval format string constructors in non-constant contexts.
    fmt_base_h = File.join(installer.sandbox.root, 'fmt/include/fmt/base.h')
    if File.exist?(fmt_base_h)
      content = File.read(fmt_base_h)
      patched = content
        .gsub(
          '#elif defined(__cpp_consteval)',
          '#elif defined(__cpp_consteval) && 0 // disabled for Xcode 26.5 Clang'
        )
        .gsub(
          '#elif FMT_GCC_VERSION >= 1002 || FMT_CLANG_VERSION >= 1101',
          '#elif (FMT_GCC_VERSION >= 1002 || FMT_CLANG_VERSION >= 1101) && 0 // disabled for Xcode 26.5 Clang'
        )
      if content != patched
        File.chmod(0644, fmt_base_h)
        File.write(fmt_base_h, patched)
        Pod::UI.puts '[patch] Disabled consteval in fmt/base.h for Xcode 26.5 compatibility'
      end
    end
  end
end
